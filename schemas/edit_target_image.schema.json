{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Edit Target Image v2 Spec",
  "type": "object",
  "required": ["asset_name", "task_type", "intended_use", "image_type", "reference_images", "preserve", "change", "ignore"],
  "properties": {
    "asset_name": {"type": "string"},
    "task_type": {"const": "edit_target_image"},
    "intended_use": {"type": "string"},
    "image_type": {"type": "string"},
    "reference_images": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["path", "role"],
        "properties": {
          "path": {"type": "string"},
          "role": {"const": "edit_target"}
        }
      }
    },
    "preserve": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "change": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "ignore": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "subject": {"type": "object"},
    "composition": {"type": "object"},
    "scene_direction": {"type": "object"},
    "style_direction": {"type": "object"},
    "model": {"type": "object"},
    "negative_profile": {"type": "object"}
  }
}
