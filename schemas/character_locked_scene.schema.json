{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/generate-high-quality-art-image2/character_locked_scene.schema.json",
  "title": "character_locked_scene",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "task_type",
    "reference_lock",
    "immutable_identity",
    "allowed_changes",
    "composition",
    "quality_checks",
    "negative_prompt",
    "output_format"
  ],
  "properties": {
    "task_type": {
      "const": "character_locked_scene",
      "description": "Same-character locked scene generation."
    },
    "mode": {
      "type": "string",
      "enum": ["prompt_only", "advisor", "host_native"],
      "description": "How an agent should use this structured prompt brief."
    },
    "quality_mode": {
      "type": "string",
      "enum": ["draft", "standard", "high_fidelity", "character_lock_strict"],
      "description": "Planning hint for fidelity and quality checks; does not change runtime API behavior."
    },
    "reference_lock": {
      "type": "object",
      "description": "Source authority for identity, pose, scene, and lighting.",
      "required": ["enabled", "identity_source"],
      "properties": {
        "enabled": { "type": "boolean" },
        "identity_source": { "type": "string" },
        "pose_source": { "type": "string" },
        "scene_source": { "type": "string" },
        "lighting_source": { "type": "string" },
        "priority_rule": { "type": "string" }
      }
    },
    "immutable_identity": {
      "type": "object",
      "description": "Traits that must not change.",
      "properties": {
        "face": { "type": "string" },
        "facial_proportions": { "type": "string" },
        "hair": { "type": "string" },
        "skin_tone": { "type": "string" },
        "body_proportion": { "type": "string" },
        "age_impression": { "type": "string" },
        "temperament": { "type": "string" },
        "recognizable_traits": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "allowed_changes": {
      "type": "object",
      "description": "Allowed controlled variations.",
      "properties": {
        "attire": { "type": "string" },
        "accessories": { "type": "string" },
        "scene": { "type": "string" },
        "pose": { "type": "string" },
        "lighting": { "type": "string" },
        "hairstyle": { "type": "string" }
      }
    },
    "conditional_overrides": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "condition": { "type": "string" },
          "override": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "forbidden_changes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "appearance": { "type": "object" },
    "attire": { "type": "object" },
    "accessories": {
      "type": "array",
      "items": { "type": "object" }
    },
    "pose": { "type": "string" },
    "composition": {
      "type": "object",
      "required": ["framing", "aspect_ratio"],
      "properties": {
        "framing": { "type": "string" },
        "camera": { "type": "string" },
        "aspect_ratio": { "type": "string" },
        "crop_rule": { "type": "string" }
      }
    },
    "scene": { "type": "string" },
    "story_context": { "type": "string" },
    "camera_language": { "type": "object" },
    "lighting": { "type": "object" },
    "style": { "type": "string" },
    "symbolic_elements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "quality_checks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "negative_prompt": {
      "type": "array",
      "items": { "type": "string" }
    },
    "output_format": {
      "type": "object",
      "required": ["aspect_ratio", "output_count"],
      "properties": {
        "aspect_ratio": { "type": "string" },
        "resolution_hint": { "type": "string" },
        "file_format": { "type": "string" },
        "output_count": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
