{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/generate-high-quality-art-image2/narrative_scene.schema.json",
  "title": "narrative_scene",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "task_type",
    "reference_lock",
    "immutable_identity",
    "story_context",
    "action_now",
    "emotional_core",
    "subject",
    "scene_state",
    "camera_language",
    "lighting_logic",
    "quality_checks",
    "negative_prompt"
  ],
  "properties": {
    "task_type": {
      "const": "narrative_scene",
      "description": "Story-driven single character illustration."
    },
    "reference_lock": {
      "type": ["boolean", "object"],
      "description": "Identity and source authority rules."
    },
    "immutable_identity": {
      "type": "object",
      "description": "Traits that must remain stable under story, light, and scene changes."
    },
    "allowed_changes": {
      "type": "object",
      "description": "Narrative scene changes allowed for this task."
    },
    "forbidden_changes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "story_context": {
      "type": "string",
      "description": "What led into the visible moment."
    },
    "action_now": {
      "type": "string",
      "description": "The event happening inside the image."
    },
    "emotional_core": {
      "type": "string",
      "description": "The main emotion or tension."
    },
    "subject": {
      "type": "string",
      "description": "The main character's role in the event."
    },
    "scene_state": {
      "type": "string",
      "description": "How the scene has changed because of the event."
    },
    "camera_language": {
      "type": "object",
      "required": ["shot_type", "angle", "focus"],
      "properties": {
        "shot_type": { "type": "string" },
        "distance": { "type": "string" },
        "angle": { "type": "string" },
        "focus": { "type": "string" },
        "composition": { "type": "string" }
      }
    },
    "lighting_logic": {
      "type": "object",
      "required": ["primary_light_source"],
      "properties": {
        "primary_light_source": { "type": "string" },
        "secondary_light_source": { "type": "string" },
        "direction": { "type": "string" },
        "mood": { "type": "string" },
        "consistency_rules": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "symbolic_effects": {
      "type": "array",
      "items": { "type": "string" }
    },
    "scene": {
      "type": "object"
    },
    "pose": {
      "type": "object"
    },
    "style": {
      "type": "string"
    },
    "quality_checks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "negative_prompt": {
      "type": "array",
      "items": { "type": "string" }
    },
    "output_format": {
      "type": "object",
      "properties": {
        "aspect_ratio": { "type": "string" },
        "resolution_hint": { "type": "string" },
        "file_format": { "type": "string" },
        "output_count": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
