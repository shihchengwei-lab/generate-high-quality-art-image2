{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/generate-high-quality-art-image2/character_sheet.schema.json",
  "title": "character_sheet",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "task_type",
    "reference_lock",
    "character_identity",
    "outfit_definition",
    "layout",
    "sheet_constraints",
    "quality_checks",
    "negative_prompt"
  ],
  "properties": {
    "task_type": {
      "const": "character_sheet",
      "description": "Character setting sheet, three-view sheet, or detail sheet."
    },
    "mode": {
      "type": "string",
      "enum": ["prompt_only", "advisor", "host_native"],
      "description": "How an agent should use this structured prompt brief."
    },
    "quality_mode": {
      "type": "string",
      "enum": ["draft", "standard", "high_fidelity", "character_lock_strict"],
      "description": "Planning hint for fidelity and quality checks; does not change runtime API behavior."
    },
    "reference_lock": {
      "type": ["boolean", "object"],
      "description": "Whether the character sheet preserves a supplied reference identity."
    },
    "character_identity": {
      "type": "object",
      "description": "Identity details that must stay consistent across panels.",
      "properties": {
        "face": { "type": "string" },
        "facial_proportions": { "type": "string" },
        "hair": { "type": "string" },
        "body_proportion": { "type": "string" },
        "age_impression": { "type": "string" },
        "temperament": { "type": "string" },
        "recognizable_traits": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "outfit_definition": {
      "type": "object",
      "description": "Costume and accessory design that must remain coherent.",
      "properties": {
        "base_outfit": { "type": "string" },
        "color_palette": { "type": "string" },
        "materials": { "type": "string" },
        "silhouette": { "type": "string" },
        "footwear": { "type": "string" },
        "fixed_accessories": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "layout": {
      "type": "object",
      "required": ["canvas_ratio", "panel_count", "panels"],
      "properties": {
        "canvas_ratio": { "type": "string" },
        "aspect_ratio": { "type": "string" },
        "panel_count": { "type": "integer", "minimum": 1 },
        "panels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "front_view",
              "side_or_3quarter_view",
              "back_view",
              "face_closeup",
              "costume_detail",
              "accessory_detail"
            ]
          }
        },
        "spacing": { "type": "string" },
        "labeling": { "type": "string" }
      }
    },
    "panel_requirements": {
      "type": "object"
    },
    "sheet_constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "style": {
      "type": "object"
    },
    "quality_checks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "negative_prompt": {
      "type": "array",
      "items": { "type": "string" }
    },
    "output_format": {
      "type": "object",
      "properties": {
        "aspect_ratio": { "type": "string" },
        "resolution_hint": { "type": "string" },
        "file_format": { "type": "string" },
        "output_count": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
